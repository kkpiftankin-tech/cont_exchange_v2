# --- Kafka/Redpanda ---
KAFKA_BROKERS=redpanda:9092

# --- Services ports/addresses (docker-compose uses service DNS names) ---
GATEWAY_HTTP_PORT=8080

ORDER_FLOW_GRPC_LISTEN=0.0.0.0:50051
ORDER_FLOW_GRPC_ADDR=order_flow:50051

RISK_GRPC_LISTEN=0.0.0.0:50052
RISK_GRPC_ADDR=risk:50052

LEDGER_GRPC_LISTEN=0.0.0.0:50053
LEDGER_GRPC_ADDR=ledger:50053

MARKET_DATA_GRPC_LISTEN=0.0.0.0:50054

# Matching
BATCH_INTERVAL_MS=1000

# Matching: PostgreSQL DSN for flow_orders + solver_config (F-04).
# When unset, the matching service uses in-memory active orders (test mode).
# In docker-compose.dev.yml this is overridden inline to point at the
# postgres service.
# MATCHING_POSTGRES_DSN=host=postgres port=5432 dbname=cex user=cex password=cex

# Matching: Market Data gRPC target + reference venue name.
MARKET_DATA_GRPC_TARGET=market_data:50054
MARKET_DATA_REFERENCE_VENUE=binance

# Matching: standalone Solver gRPC listen (for replay/backtest).
MATCHING_ISOLATION_GRPC_LISTEN=0.0.0.0:50053

# Matching: Prometheus /metrics + /healthz HTTP listener port.
MATCHING_METRICS_PORT=8081
