# =============================================================================
# Staging .env template для Continuous Exchange / FOB.
#
# На сервере: cp .env-staging.example .env
# Файл .env (без -staging.example суффикса) НЕ коммитится — там могут быть
# production-овые secrets (kill-switch keys и т.п. в будущем).
#
# Этот .example — безопасный baseline: только service-discovery адреса
# внутри docker compose, без секретов.
# =============================================================================

# --- Image tag (для rolling deploy через docker compose pull) -----------------
# По умолчанию :latest. На canary-staging стенде можно зафиксировать SHA:
# IMAGE_TAG=sha-d1eb947
IMAGE_TAG=latest

# --- Kafka / Redpanda ---------------------------------------------------------
KAFKA_BROKERS=redpanda:9092

# --- Gateway ------------------------------------------------------------------
GATEWAY_HTTP_PORT=8080

# --- gRPC: per-сервис listen и адреса для клиентов ----------------------------
# (docker-compose использует service-names как DNS внутри bridge-сети)
ORDER_FLOW_GRPC_LISTEN=0.0.0.0:50051
ORDER_FLOW_GRPC_ADDR=order_flow:50051

RISK_GRPC_LISTEN=0.0.0.0:50052
RISK_GRPC_ADDR=risk:50052

LEDGER_GRPC_LISTEN=0.0.0.0:50053
LEDGER_GRPC_ADDR=ledger:50053

MARKET_DATA_GRPC_LISTEN=0.0.0.0:50054

# --- Matching solver ----------------------------------------------------------
# В dev = 1000 (1 сек). В staging немного агрессивнее для нагрузочного теста.
BATCH_INTERVAL_MS=1000
